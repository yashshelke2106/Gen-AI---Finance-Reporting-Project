# Copy to .env and fill in. Never commit your real .env.

# Which provider to use for live analysis: 'anthropic' or 'gemini'
EARNINGS_ANALYST_PROVIDER=anthropic

# --- Anthropic (paid; no permanent free tier) ---
ANTHROPIC_API_KEY=sk-ant-...
EARNINGS_ANALYST_MODEL=claude-3-5-sonnet-latest

# --- Gemini (has a free tier at aistudio.google.com/apikey) ---
# Set EARNINGS_ANALYST_PROVIDER=gemini to use this instead.
GEMINI_API_KEY=
EARNINGS_ANALYST_GEMINI_MODEL=gemini-2.5-flash

# SEC EDGAR requires a descriptive User-Agent with contact info per their fair-access policy.
# Format: "Sample Company AdminContact admin@example.com"
SEC_EDGAR_USER_AGENT=earnings-analyst yashshelke00@gmail.com
